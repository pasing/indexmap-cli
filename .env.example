# indexmap-cli — server configuration
# Copy this file to .env and fill in your values.

# Set to false to enforce TLS certificate verification (default: true = skip verification)
INDEXMAP_SKIP_SSL_VERIFY=true

# analyze/download command defaults (optional, can also be set via CLI arguments)
INDEXMAP_BASE_URL=https://<your-geoserver-domain>/geoserver/
INDEXMAP_WORKSPACE=<your-workspace>
INDEXMAP_LAYER=<your-layer>
INDEXMAP_URL_FIELD=<your-url-field>
INDEXMAP_OUTPUT_DIR=./data/<your-output-dir>/

# merge command defaults (optional, can also be set via CLI arguments)
INDEXMAP_INPUT_DIR=./data/<your-output-dir>/
INDEXMAP_OUTPUT_FILE=./data/<your-output-file>.tif
INDEXMAP_OUTPUT_FORMAT=auto
INDEXMAP_GLOB=*.tif
INDEXMAP_INPUT_CRS=<your-input-crs>